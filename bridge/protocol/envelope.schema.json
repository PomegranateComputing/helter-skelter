{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "envelope.schema.json",
  "title": "Helter Skelter bridge<->orchestrator envelope",
  "description": "Top-level wire message. `payload`'s deep shape depends on `kind` and is validated against the matching schema in messages/ (and, for command.request, commands/) by the test harness in core/common and bridge/openrct2-plugin, not by this file via $ref -- see docs/PROTOCOL.md for why.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "message_id",
    "timestamp",
    "simulation_id",
    "kind",
    "payload",
    "correlation_id",
    "status",
    "error"
  ],
  "properties": {
    "protocol_version": {
      "const": "0.1.0"
    },
    "message_id": {
      "description": "UUIDv7 (time-ordered), generated by the sender of this message.",
      "$ref": "#/$defs/uuidv7"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "simulation_id": {
      "description": "Stable identifier for the running simulation this message belongs to.",
      "$ref": "#/$defs/uuid"
    },
    "kind": {
      "enum": [
        "hello",
        "heartbeat",
        "observation.snapshot",
        "command.request",
        "command.result",
        "shutdown",
        "ack"
      ]
    },
    "correlation_id": {
      "description": "message_id of the message this one responds to. Mandatory (non-null) for command.result and ack.",
      "anyOf": [
        { "$ref": "#/$defs/uuidv7" },
        { "type": "null" }
      ]
    },
    "status": {
      "anyOf": [
        { "enum": ["ok", "error"] },
        { "type": "null" }
      ]
    },
    "error": {
      "anyOf": [
        { "$ref": "#/$defs/error" },
        { "type": "null" }
      ]
    },
    "payload": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "command.result" } } },
      "then": {
        "required": ["correlation_id"],
        "properties": { "correlation_id": { "$ref": "#/$defs/uuidv7" } }
      }
    },
    {
      "if": { "properties": { "kind": { "const": "ack" } } },
      "then": {
        "required": ["correlation_id"],
        "properties": { "correlation_id": { "$ref": "#/$defs/uuidv7" } }
      }
    }
  ],
  "$defs": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "uuidv7": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-7[0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    }
  }
}
